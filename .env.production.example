APP_NAME="E-Voting RSA SHA-256"
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-a-long-random-secret
APP_PORT=8000

POSTGRES_DB=evoting_db
POSTGRES_USER=evoting_user
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://evoting_user:change-this-strong-db-password@postgres:5432/evoting_db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

ADMIN_PRIVATE_KEY_PATH=/data/keys/admin_private_key.pem
ADMIN_PUBLIC_KEY_PATH=/data/keys/admin_public_key.pem
SYSTEM_PRIVATE_KEY_PATH=/data/keys/system_private_key.pem
SYSTEM_PUBLIC_KEY_PATH=/data/keys/system_public_key.pem

ENABLE_DEV_ROUTES=false
RUN_MIGRATIONS=true
GENERATE_KEYS_IF_MISSING=true
