# ═══════════════════════════════════════════════════════
#  MODE PRODUCTION — pakai akun @student.itera.ac.id
#  (gunakan setelah admin IT ITERA acc Google Cloud app)
# ═══════════════════════════════════════════════════════

APP_NAME=E-Voting RSA SHA-256
APP_SECRET_KEY=ganti-dengan-random-string-32-karakter-atau-lebih

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/evoting_db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti-password-admin

# Google OAuth — isi dari console.cloud.google.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# URL aplikasi (tanpa trailing slash)
APP_BASE_URL=https://evoting.itera.ac.id   # ganti dengan domain production

# Hanya mahasiswa ITERA yang boleh login
ALLOWED_EMAIL_DOMAINS=student.itera.ac.id

# Email dosen/admin yang boleh akses dashboard admin via Google
ADMIN_GOOGLE_EMAILS=dosen@itera.ac.id,admin@itera.ac.id

# Mode: production = NIM 9 digit wajib ada di email
OAUTH_MODE=production
