# ═══════════════════════════════════════════════════════
#  MODE DEMO — simulasi dengan akun Gmail biasa
#  (untuk presentasi / testing tanpa akun ITERA asli)
# ═══════════════════════════════════════════════════════

APP_NAME=E-Voting RSA SHA-256 (DEMO)
APP_SECRET_KEY=demo-secret-key-ganti-ini

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/evoting_db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Google OAuth — isi dari console.cloud.google.com
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

APP_BASE_URL=http://localhost:8000

# Mode demo: terima semua domain Gmail
ALLOWED_EMAIL_DOMAINS=gmail.com

# Email kamu sendiri untuk masuk sebagai admin
ADMIN_GOOGLE_EMAILS=emailkamu@gmail.com,temanmu@gmail.com

# Mode: demo = voter_id diambil dari username sebelum @
#              titik diganti underscore
#              contoh: budi.santoso@gmail.com → voter_id = "budi_santoso"
OAUTH_MODE=demo

# ─── Cara setup voter untuk demo ───────────────────────────────────────────
# Misalnya peserta demo login pakai: budi.santoso@gmail.com
# Maka di database, daftarkan voter dengan voter_id = "budi_santoso"
# Bisa lewat seed_data.py atau admin panel
# ───────────────────────────────────────────────────────────────────────────
